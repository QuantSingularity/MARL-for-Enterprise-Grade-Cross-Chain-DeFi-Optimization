{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# MARL Training Demo\n",
    "\n",
    "This notebook demonstrates training QMIX and MAPPO agents on the cross-chain environment.\n",
    "\n",
    "## Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../src')\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import torch\n",
    "from envs.cross_chain_env import CrossChainEnv, Chain, Bridge, Pool\n",
    "from agents.qmix import QMIXAgent\n",
    "from agents.mappo import MAPPOAgent\n",
    "from agents.baselines import RandomAgent"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Create Environment"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_env():\n",
    "    chains = [\n",
    "        Chain(\"Ethereum\", 1, 12.0, 20.0, 0.1),\n",
    "        Chain(\"Arbitrum\", 42161, 0.25, 0.1, 0.05)\n",
    "    ]\n",
    "    \n",
    "    bridges = [\n",
    "        Bridge(\"Bridge\", \"Ethereum\", \"Arbitrum\", 10000.0, 600.0, 120.0, 0.01, 10)\n",
    "    ]\n",
    "    \n",
    "    pools = {\n",
    "        \"Ethereum\": [Pool(\"ETH\", \"USDC\", 1000.0, 2000000.0, 30)],\n",
    "        \"Arbitrum\": [Pool(\"ETH\", \"USDC\", 500.0, 1000000.0, 30)]\n",
    "    }\n",
    "    \n",
    "    return CrossChainEnv(chains, bridges, pools, max_steps=50)\n",
    "\n",
    "env = create_env()\n",
    "print(f\"Observation dim: {env.observation_space.shape[0]}\")\n",
    "print(f\"Action dim: {env.action_space.shape[0]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Train QMIX Agent"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize QMIX agent\n",
    "n_agents = 2\n",
    "obs_dim = env.observation_space.shape[0] // n_agents\n",
    "state_dim = env.observation_space.shape[0]\n",
    "n_actions = 5\n",
    "\n",
    "qmix_agent = QMIXAgent(\n",
    "    n_agents=n_agents,\n",
    "    obs_dim=obs_dim,\n",
    "    state_dim=state_dim,\n",
    "    n_actions=n_actions,\n",
    "    hidden_dim=64,\n",
    "    gamma=0.99,\n",
    "    lr=5e-4,\n",
    "    device='cpu'\n",
    ")\n",
    "\n",
    "# Training loop\n",
    "n_episodes = 30\n",
    "qmix_rewards = []\n",
    "\n",
    "for episode in range(n_episodes):\n",
    "    obs, _ = env.reset(seed=episode)\n",
    "    qmix_agent.reset_hidden_states()\n",
    "    \n",
    "    episode_reward = 0\n",
    "    done = False\n",
    "    \n",
    "    while not done:\n",
    "        obs_split = [obs[i*obs_dim:(i+1)*obs_dim] for i in range(n_agents)]\n",
    "        actions = qmix_agent.select_actions(obs_split)\n",
    "        \n",
    "        action = np.array([actions[0], 0, 100.0, 0])\n",
    "        obs, reward, terminated, truncated, info = env.step(action)\n",
    "        \n",
    "        episode_reward += reward\n",
    "        done = terminated or truncated\n",
    "    \n",
    "    qmix_rewards.append(episode_reward)\n",
    "    \n",
    "    if episode % 5 == 0:\n",
    "        print(f\"QMIX Episode {episode}: Reward = {episode_reward:.4f}\")\n",
    "\n",
    "print(f\"\\nAverage reward (last 10): {np.mean(qmix_rewards[-10:]):.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Train MAPPO Agent"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize MAPPO agent\n",
    "mappo_agent = MAPPOAgent(\n",
    "    n_agents=n_agents,\n",
    "    obs_dim=obs_dim,\n",
    "    state_dim=state_dim,\n",
    "    n_actions=n_actions,\n",
    "    hidden_dim=64,\n",
    "    lr_actor=3e-4,\n",
    "    lr_critic=1e-3,\n",
    "    gamma=0.99,\n",
    "    device='cpu'\n",
    ")\n",
    "\n",
    "# Training loop\n",
    "mappo_rewards = []\n",
    "\n",
    "for episode in range(n_episodes):\n",
    "    obs, _ = env.reset(seed=episode + 100)\n",
    "    \n",
    "    # Collect trajectory\n",
    "    trajectory = {\n",
    "        'observations': [],\n",
    "        'actions': [],\n",
    "        'rewards': [],\n",
    "        'states': [],\n",
    "        'dones': [],\n",
    "        'old_log_probs': []\n",
    "    }\n",
    "    \n",
    "    done = False\n",
    "    episode_reward = 0\n",
    "    \n",
    "    while not done:\n",
    "        obs_split = [obs[i*obs_dim:(i+1)*obs_dim] for i in range(n_agents)]\n",
    "        actions = mappo_agent.select_actions(obs_split)\n",
    "        \n",
    "        trajectory['observations'].append(obs)\n",
    "        trajectory['actions'].append(actions)\n",
    "        trajectory['states'].append(obs)\n",
    "        trajectory['old_log_probs'].append([0.0, 0.0])\n",
    "        \n",
    "        action = np.array([actions[0], 0, 100.0, 0])\n",
    "        obs, reward, terminated, truncated, info = env.step(action)\n",
    "        \n",
    "        trajectory['rewards'].append(reward)\n",
    "        trajectory['dones'].append(float(terminated or truncated))\n",
    "        \n",
    "        episode_reward += reward\n",
    "        done = terminated or truncated\n",
    "    \n",
    "    mappo_rewards.append(episode_reward)\n",
    "    \n",
    "    # Update (simplified - no batching)\n",
    "    if len(trajectory['rewards']) > 0:\n",
    "        batch = {\n",
    "            'observations': torch.FloatTensor(np.array(trajectory['observations'])).view(-1, n_agents, obs_dim),\n",
    "            'actions': torch.LongTensor(np.array(trajectory['actions'])),\n",
    "            'rewards': torch.FloatTensor(trajectory['rewards']),\n",
    "            'states': torch.FloatTensor(np.array(trajectory['states'])),\n",
    "            'dones': torch.FloatTensor(trajectory['dones']),\n",
    "            'old_log_probs': torch.FloatTensor(np.array(trajectory['old_log_probs']))\n",
    "        }\n",
    "        mappo_agent.update(batch, n_epochs=3)\n",
    "    \n",
    "    if episode % 5 == 0:\n",
    "        print(f\"MAPPO Episode {episode}: Reward = {episode_reward:.4f}\")\n",
    "\n",
    "print(f\"\\nAverage reward (last 10): {np.mean(mappo_rewards[-10:]):.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Compare with Random Baseline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "random_agent = RandomAgent(n_agents=n_agents, n_actions=n_actions)\n",
    "random_rewards = []\n",
    "\n",
    "for episode in range(n_episodes):\n",
    "    obs, _ = env.reset(seed=episode + 200)\n",
    "    \n",
    "    episode_reward = 0\n",
    "    done = False\n",
    "    \n",
    "    while not done:\n",
    "        obs_split = [obs[i*obs_dim:(i+1)*obs_dim] for i in range(n_agents)]\n",
    "        actions = random_agent.select_actions(obs_split)\n",
    "        \n",
    "        action = np.array([actions[0], 0, 100.0, 0])\n",
    "        obs, reward, terminated, truncated, info = env.step(action)\n",
    "        \n",
    "        episode_reward += reward\n",
    "        done = terminated or truncated\n",
    "    \n",
    "    random_rewards.append(episode_reward)\n",
    "\n",
    "print(f\"Random Average reward: {np.mean(random_rewards):.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Visualize Training Progress"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Episode rewards\n",
    "axes[0].plot(qmix_rewards, label='QMIX', alpha=0.7)\n",
    "axes[0].plot(mappo_rewards, label='MAPPO', alpha=0.7)\n",
    "axes[0].plot(random_rewards, label='Random', alpha=0.5, linestyle='--')\n",
    "axes[0].set_xlabel('Episode')\n",
    "axes[0].set_ylabel('Total Reward')\n",
    "axes[0].set_title('Episode Rewards')\n",
    "axes[0].legend()\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "# Moving average\n",
    "window = 5\n",
    "qmix_ma = np.convolve(qmix_rewards, np.ones(window)/window, mode='valid')\n",
    "mappo_ma = np.convolve(mappo_rewards, np.ones(window)/window, mode='valid')\n",
    "random_ma = np.convolve(random_rewards, np.ones(window)/window, mode='valid')\n",
    "\n",
    "axes[1].plot(qmix_ma, label='QMIX', linewidth=2)\n",
    "axes[1].plot(mappo_ma, label='MAPPO', linewidth=2)\n",
    "axes[1].plot(random_ma, label='Random', linestyle='--')\n",
    "axes[1].set_xlabel('Episode')\n",
    "axes[1].set_ylabel('Reward (Moving Avg)')\n",
    "axes[1].set_title(f'Rewards (Window={window})')\n",
    "axes[1].legend()\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Summary Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=" * 50)\n",
    "print(\"Training Summary\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "agents = {\n",
    "    'QMIX': qmix_rewards,\n",
    "    'MAPPO': mappo_rewards,\n",
    "    'Random': random_rewards\n",
    "}\n",
    "\n",
    "for name, rewards in agents.items():\n",
    "    print(f\"\\n{name}:\")\n",
    "    print(f\"  Mean reward: {np.mean(rewards):.4f}\")\n",
    "    print(f\"  Std reward: {np.std(rewards):.4f}\")\n",
    "    print(f\"  Min reward: {np.min(rewards):.4f}\")\n",
    "    print(f\"  Max reward: {np.max(rewards):.4f}\")\n",
    "    print(f\"  Last 10 avg: {np.mean(rewards[-10:]):.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Save Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save trained models\n",
    "import os\n",
    "os.makedirs('../checkpoints', exist_ok=True)\n",
    "\n",
    "qmix_agent.save('../checkpoints/qmix_demo.pth')\n",
    "mappo_agent.save('../checkpoints/mappo_demo.pth')\n",
    "\n",
    "print(\"Models saved to ../checkpoints/\")"
   ]
  }
 ],
